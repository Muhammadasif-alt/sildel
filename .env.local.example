# Sildel — local environment variables
#
# 1. Copy this file to `.env.local` in the project root.
# 2. Replace the placeholders below with your real values.
# 3. Restart `npm run dev`.
#
# `.env.local` is gitignored — never commit secrets.

# ─────────────────────────────────────────────────────────────
# MySQL connection string (Prisma).
# Local dev: use XAMPP/MAMP or any MySQL 5.7+ server.
# cPanel: create a database + user in MySQL Databases, then
# format as: mysql://USER:PASS@HOST:3306/DB
# Example for local XAMPP default:
#   mysql://root:@127.0.0.1:3306/sildel
# ─────────────────────────────────────────────────────────────
DATABASE_URL="mysql://root:@127.0.0.1:3306/sildel"

# ─────────────────────────────────────────────────────────────
# Admin dashboard credentials.
# The Sildel team logs into /admin with these.
# ADMIN_SESSION_SECRET must be at least 32 random characters.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# ─────────────────────────────────────────────────────────────
ADMIN_EMAIL="hello@sildel.pt"
ADMIN_PASSWORD="change-me-to-a-strong-password"
ADMIN_SESSION_SECRET="replace-with-48-bytes-of-random-hex"

# ─────────────────────────────────────────────────────────────
# Customer auth session secret.
# Signs the `sildel-user` JWT cookie used by /account login/register.
# Must be at least 32 random characters — generate the same way as above.
# ─────────────────────────────────────────────────────────────
SILDEL_SESSION_SECRET="replace-with-48-bytes-of-random-hex"
