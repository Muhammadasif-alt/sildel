// Sildel — Prisma schema (MySQL).
//
// Only three tables: the admin-CRUD surfaces the founder actually uses
// (Products, Blogs, Media). Everything else — editorial chrome, site
// settings, contact submissions etc. — stays in static TS files for
// the cPanel deploy (founder feedback, June 2026: "bas product add
// krna hai, blogs add krna ho gay, baki ni krna kuch b").
//
// MySQL specifics:
//  - Arrays + structured payloads (gallery, longDescription, blog body
//    blocks) go in JSON columns. cPanel MySQL 5.7+ supports JSON natively.
//  - Enums are Prisma enums (compiled to CHECK on most engines; MySQL
//    accepts them as VARCHAR + Prisma-side validation).
//  - Localized text (MediaAsset alt) is split into two columns rather
//    than nested JSON so admin filters/search stay sargable.

generator client {
  provider = "prisma-client-js"
}

// Note: `url` reads from process.env at runtime. Prisma CLI loads it
// from .env in the project root; for our setup we keep secrets in
// .env.local instead and chain dotenv-cli in the npm scripts (see
// "db:*" in package.json) so DATABASE_URL propagates correctly.

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum ProductCategory {
  Sculpture
  Tables
  Lighting
  FineArts // stored as "FineArts" — app maps to "Fine Arts" for display
}

enum BlogTag {
  Atelier
  Forest
  Craft
  Material
  Collectors
}

model Product {
  id              Int              @id @default(autoincrement())
  slug            String           @unique @db.VarChar(120)
  name            String           @db.VarChar(160)
  tagline         String           @default("") @db.VarChar(255)
  category        ProductCategory
  priceCents      Int
  currency        String           @default("EUR") @db.VarChar(8)
  badge           String?          @db.VarChar(120)
  material        String?          @db.VarChar(255)
  description     String           @db.Text
  longDescription Json             @default("[]") // string[]
  image           String           @db.VarChar(500)
  gallery         Json             @default("[]") // string[]
  inStock         Boolean          @default(true)
  editionSize     Int              @default(1)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([category])
  @@index([inStock])
}

model Blog {
  id          Int      @id @default(autoincrement())
  slug        String   @unique @db.VarChar(160)
  title       String   @db.VarChar(255)
  excerpt     String   @db.Text
  image       String   @db.VarChar(500)
  imageAlt    String   @default("") @db.VarChar(255)
  author      String   @db.VarChar(120)
  authorRole  String   @default("") @db.VarChar(160)
  date        DateTime
  readMinutes Int      @default(5)
  tag         BlogTag
  featured    Boolean  @default(false)
  published   Boolean  @default(true)
  body        Json     @default("[]") // Array of { kind, text?, author?, src?, alt?, caption? }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tag])
  @@index([featured])
  @@index([published])
}

model MediaAsset {
  id        Int      @id @default(autoincrement())
  url       String   @unique @db.VarChar(500)
  filename  String   @db.VarChar(255)
  mimeType  String   @db.VarChar(120)
  size      Int      @default(0)
  width     Int      @default(0)
  height    Int      @default(0)
  altPt     String   @default("") @db.VarChar(255)
  altEn     String   @default("") @db.VarChar(255)
  title     String   @default("") @db.VarChar(255)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([mimeType])
}

// Marketing pages CMS overrides. One row per pageKey ("home", "our-story",
// etc.). Holds BOTH the block-based editor state (`blocks` + `seo`) and
// the schema-driven field overrides (`sections`) used by simple read-only
// pages like /privacy, /terms, /shipping.
model PageContent {
  id        Int      @id @default(autoincrement())
  pageKey   String   @unique @db.VarChar(80)
  sections  Json     @default("{}")
  blocks    Json     @default("[]")
  seo       Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Singleton config edited via /admin/settings. Use `singletonKey = "main"`.
// All shape fields (brand, nav, footer, social, contact, brandVideo) live
// in the JSON column so we can evolve the shape without migrations.
model SiteSettings {
  id           Int      @id @default(autoincrement())
  singletonKey String   @unique @default("main") @db.VarChar(40)
  data         Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// One row per admin email (we only have one admin in practice).
model AdminProfile {
  id          Int      @id @default(autoincrement())
  email       String   @unique @db.VarChar(255)
  displayName String   @default("") @db.VarChar(160)
  avatarUrl   String   @default("") @db.VarChar(500)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Newsletter signups (from the public footer form).
model Subscriber {
  id        Int      @id @default(autoincrement())
  email     String   @unique @db.VarChar(255)
  source    String   @default("footer") @db.VarChar(60)
  createdAt DateTime @default(now())

  @@index([source])
}

// Contact form submissions (from /contact).
model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(120)
  email     String   @db.VarChar(255)
  phone     String   @default("") @db.VarChar(60)
  subject   String   @default("") @db.VarChar(255)
  message   String   @db.Text
  locale    String   @default("en") @db.VarChar(8)
  createdAt DateTime @default(now())

  @@index([createdAt])
}